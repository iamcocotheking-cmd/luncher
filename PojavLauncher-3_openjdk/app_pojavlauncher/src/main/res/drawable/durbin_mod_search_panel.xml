<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="270"
                android:startColor="#77141416"
                android:centerColor="#55101012"
                android:endColor="#33070708" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
            <padding android:left="18dp" android:right="18dp" android:top="18dp" android:bottom="18dp" />
        </shape>
    </item>
    <item android:top="1dp" android:left="1dp" android:right="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="27dp" />
            <stroke android:width="1dp" android:color="#18FFFFFF" />
        </shape>
    </item>
</layer-list>
