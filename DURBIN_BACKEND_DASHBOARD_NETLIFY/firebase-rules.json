{
  "rules": {
    "durbin": {
      "news": {
        ".read": true,
        ".write": "auth != null && root.child('durbin/admins').child(auth.uid).val() === true",
        ".indexOn": ["timestamp"]
      },
      "pvpTierLists": {
        ".read": true,
        ".write": "auth != null && root.child('durbin/admins').child(auth.uid).val() === true"
      },
      "userRanks": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('durbin/admins').child(auth.uid).val() === true"
      },
      "userRanksByEmail": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('durbin/admins').child(auth.uid).val() === true"
      },
      "ads": {
        ".read": true,
        ".write": "auth != null && root.child('durbin/admins').child(auth.uid).val() === true"
      },
      "servers": {
        ".read": true,
        ".write": "auth != null && root.child('durbin/admins').child(auth.uid).val() === true",
        ".indexOn": ["order", "featured", "enabled"]
      },
      "admins": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('durbin/admins').child(auth.uid).val() === true"
      }
    }
  }
}
