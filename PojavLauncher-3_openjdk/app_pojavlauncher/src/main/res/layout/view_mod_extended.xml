<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="12dp">

    <TextView
        android:id="@+id/mod_extended_error_textview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Could not load versions. Try another mod or check internet."
        android:textColor="#FFFF5555"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/mod_extended_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pick version"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/mod_extended_error_textview" />

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/mod_extended_version_spinner"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/durbin_mod_search_field"
        android:minHeight="54dp"
        app:layout_constraintTop_toBottomOf="@+id/mod_extended_label" />

    <Button
        android:id="@+id/mod_extended_select_version_button"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/durbin_mod_install_button"
        android:enabled="false"
        android:text="INSTALL TO MODS FOLDER"
        android:textAllCaps="false"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/mod_extended_version_spinner" />

</androidx.constraintlayout.widget.ConstraintLayout>
