<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="9dp"
    android:background="@drawable/durbin_mod_item_card">

    <FrameLayout
        android:id="@+id/mod_thumbnail_frame"
        android:layout_width="78dp"
        android:layout_height="78dp"
        android:background="@drawable/durbin_mod_thumbnail_bg"
        android:padding="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/mod_thumbnail_imageview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:src="@mipmap/ic_launcher_foreground" />
    </FrameLayout>

    <ImageView
        android:id="@+id/mod_source_imageview"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="2dp"
        android:scaleType="centerInside"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@mipmap/ic_launcher_foreground" />

    <TextView
        android:id="@+id/mod_title_textview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="10dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFFFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@+id/mod_source_imageview"
        app:layout_constraintStart_toEndOf="@+id/mod_thumbnail_frame"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Sodium" />

    <TextView
        android:id="@+id/mod_body_textview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textColor="#B8FFFFFF"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/mod_thumbnail_frame"
        app:layout_constraintTop_toBottomOf="@+id/mod_title_textview"
        tools:text="A modern rendering engine and client-side optimization mod." />

    <TextView
        android:id="@+id/mod_choose_version_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/durbin_mod_chip"
        android:text="Choose version"
        android:textColor="#FFFF7A00"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@+id/mod_thumbnail_frame"
        app:layout_constraintTop_toBottomOf="@+id/mod_body_textview" />

    <ViewStub
        android:id="@+id/mod_limited_state_stub"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout="@layout/view_mod_extended"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/mod_thumbnail_frame" />

</androidx.constraintlayout.widget.ConstraintLayout>
