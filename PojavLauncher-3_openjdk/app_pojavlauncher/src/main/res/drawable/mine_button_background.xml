<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient android:startColor="#CCFF7A00" android:endColor="#AAFF3D00" android:angle="0" />
            <stroke android:width="1dp" android:color="#FFFFB36A" />
            <padding android:left="12dp" android:right="12dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="#22333333" />
            <stroke android:width="1dp" android:color="#33FFFFFF" />
            <padding android:left="12dp" android:right="12dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient android:startColor="#55FF7A00" android:endColor="#22FF7A00" android:angle="0" />
            <stroke android:width="1dp" android:color="#80FF7A00" />
            <padding android:left="12dp" android:right="12dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
</selector>
